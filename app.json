{
  "expo": {
    "name": "calorie-compass",
    "slug": "calorie-compass",
    "version": "1.0.0",
    "scheme": "calorie-compass",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF9"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.caloriecompass"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite usar la camara para escanear codigos de barras de alimentos."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permite usar la camara para fotografiar platos y etiquetas nutricionales.",
          "photosPermission": "Permite acceder a tus fotos para reutilizar imagenes nutricionales cuando haga falta."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a93ee4bd-58b3-4e21-a072-6c268407041e"
      }
    }
  }
}
